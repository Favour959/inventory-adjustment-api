# ── Virtual environment ───────────────────────────────────────────
# The venv is tied to your specific machine. Anyone who clones this
# project creates their own fresh venv using requirements.txt instead.
inventory_env/
venv/
env/
.venv/

# ── Database ──────────────────────────────────────────────────────
# Contains your local test data. Everyone starts with a clean
# empty database by running: python manage.py migrate
db.sqlite3
*.sqlite3

# ── Python cache files ────────────────────────────────────────────
# Auto-generated by Python when it runs your code. Never belongs
# in version control -- Python recreates them automatically.
__pycache__/
*.py[cod]
*$py.class
*.pyc

# ── Django generated files ────────────────────────────────────────
# Static files collected for production -- not needed in development.
staticfiles/
/static/

# ── Environment variables ─────────────────────────────────────────
# If you ever store secrets (API keys, passwords) in a .env file,
# this ensures they never accidentally get uploaded to GitHub.
.env
.env.*
*.env

# ── OS generated junk ────────────────────────────────────────────
# Files your operating system creates automatically that have
# nothing to do with your project.
.DS_Store          # Mac
Thumbs.db          # Windows
desktop.ini        # Windows

# ── VS Code settings ──────────────────────────────────────────────
# Your personal editor settings -- other people have their own.
.vscode/

# ── PyCharm settings ──────────────────────────────────────────────
.idea/